# =========================
# IDP 基础配置
# =========================
# IDP 服务地址，默认使用 http://idp.fdvctte.info
IDP_BASE=http://idp.fdvctte.info
# IDP 访问码/点数 token；真实值只写到 .env，不要提交到仓库
IDP_TOKEN=
# IDP OAuth client_id；不填时由程序/IDP 默认策略选择
IDP_CLIENT_ID=
# IDP 渠道 ID；不填时按 client_id 或 IDP 返回值自动选择
IDP_CHANNEL_ID=
# 生成账号使用的邮箱后缀；不填时由 IDP 自动选择
IDP_DOMAIN=

# =========================
# Codex OAuth 配置
# =========================
# Codex OAuth client_id；默认是 Codex CLI 使用的公开 client_id
CODEX_CLIENT_ID=app_EMoamEEZ73f0CkXaXp7hrann
# Codex OAuth 回调地址；需要和授权流程中的 redirect_uri 一致
CODEX_REDIRECT_URI=http://localhost:1455/auth/callback
# Codex OAuth scope；offline_access 用于获取 refresh token
CODEX_SCOPE=openid profile email offline_access

# =========================
# HTTP 代理配置（可选）
# =========================
# HTTP 代理，例如 http://127.0.0.1:7890；不需要则留空
HTTP_PROXY=
# HTTPS 代理，例如 http://127.0.0.1:7890；不需要则留空
HTTPS_PROXY=

# =========================
# Sub2API 管理端配置
# =========================
# Sub2API 服务地址，例如 https://sub2api.example.com
SUB2API_URL=
# Sub2API 管理员登录邮箱
SUB2API_EMAIL=
# Sub2API 管理员登录密码；真实值只写到 .env，不要提交到仓库
SUB2API_PASSWORD=
# Sub2API 分组 ID，多个用逗号分隔；检测错误账号时默认读取此值
SUB2API_GROUP=5
# 写入 Sub2API 后允许使用的模型白名单，多个用逗号分隔
SUB2API_MODEL_WHITELIST=gpt-5.4,gpt-5.4-mini,gpt-5.5,gpt-image-2
# Sub2API 账号并发额度
SUB2API_CONCURRENCY=10
# Sub2API 账号优先级
SUB2API_PRIORITY=1
# Sub2API 倍率配置
SUB2API_RATE_MULTIPLIER=1

# =========================
# 导出目标配置
# =========================
# 导出目标：sub2api / cpa / sub2api,cpa / none
EXPORT_TARGETS=sub2api

# =========================
# CLIProxyAPI（CPA）管理端配置
# =========================
# CLIProxyAPI 地址，例如 http://127.0.0.1:8317
CPA_URL=
# CLIProxyAPI remote-management.secret-key 或 MANAGEMENT_PASSWORD；真实值只写到 .env，不要提交到仓库
CPA_MANAGEMENT_KEY=
# CPA auth 文件优先级
CPA_PRIORITY=1
# CPA auth 文件备注
CPA_NOTE=Idp Team Automation

# =========================
# 运行时配置
# =========================
# 单账号运行产物目录；批量模式会自动生成 artifacts/batch_YYYYMMDD_HHMMSS
ARTIFACT_DIR=artifacts/idp_codex
# HTTP 请求超时时间，单位：秒
REQUEST_TIMEOUT=30
